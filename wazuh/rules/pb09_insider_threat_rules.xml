<group name="insider_threat,privileged_access,">
  <rule id="100080" level="12">
    <decoded_as>json</decoded_as>
    <match>admin_off_hours|privileged_after_hours|admin_login_night</match>
    <description>PB-09 | Privileged account login outside business hours</description>
    <group>insider_threat,privileged_access,pb09,</group>
  </rule>
  <rule id="100081" level="13">
    <decoded_as>json</decoded_as>
    <match>admin_lateral_spread|mass_host_auth|unusual_admin_access</match>
    <description>PB-09 | Admin account authenticating to unusual number of systems</description>
    <group>insider_threat,lateral_movement,pb09,</group>
  </rule>
  <rule id="100082" level="13">
    <decoded_as>json</decoded_as>
    <match>bulk_sensitive_access|mass_confidential_read|sensitive_dir_bulk</match>
    <description>PB-09 | Bulk access to sensitive directories detected</description>
    <group>insider_threat,file_access,pb09,</group>
  </rule>
  <rule id="100083" level="14">
    <decoded_as>json</decoded_as>
    <match>ad_object_modified|gpo_change_unauthorized|directory_service_change</match>
    <description>PB-09 | Unauthorized AD or GPO modification detected</description>
    <group>insider_threat,ad_modification,pb09,</group>
  </rule>
  <rule id="100084" level="15">
    <decoded_as>json</decoded_as>
    <match>security_log_cleared|audit_log_deleted|event_log_wiped|audit_policy_modified</match>
    <description>PB-09 | Security audit log cleared or audit policy modified</description>
    <group>insider_threat,log_tampering,pb09,</group>
  </rule>
  <rule id="100085" level="14">
    <decoded_as>json</decoded_as>
    <match>privileged_account_created|admin_account_offhours|service_account_created_night</match>
    <description>PB-09 | Privileged account created outside change window</description>
    <group>insider_threat,account_creation,pb09,</group>
  </rule>
</group>

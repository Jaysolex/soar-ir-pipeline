<group name="vulnerability,cve,">
  <rule id="100060" level="13">
    <decoded_as>json</decoded_as>
    <match>critical_vulnerability|cvss_critical|cvss_score_9</match>
    <description>PB-07 | Critical vulnerability detected — CVSS score 9.0 or higher</description>
    <group>vulnerability,critical_cve,pb07,</group>
  </rule>
  <rule id="100061" level="12">
    <decoded_as>json</decoded_as>
    <match>high_vulnerability|internet_facing_vuln|critical_host_vuln</match>
    <description>PB-07 | High vulnerability on critical infrastructure host</description>
    <group>vulnerability,high_cve,pb07,</group>
  </rule>
  <rule id="100062" level="15">
    <decoded_as>json</decoded_as>
    <match>cisa_kev|known_exploited|actively_exploited_cve</match>
    <description>PB-07 | CVE in CISA Known Exploited Vulnerabilities catalog</description>
    <group>vulnerability,cisa_kev,pb07,</group>
  </rule>
  <rule id="100063" level="12">
    <decoded_as>json</decoded_as>
    <match>sla_breach|unpatched_30_days|patch_overdue</match>
    <description>PB-07 | High vulnerability approaching SLA breach — unpatched 30 days or more</description>
    <group>vulnerability,sla_breach,pb07,</group>
  </rule>
  <rule id="100064" level="14">
    <decoded_as>json</decoded_as>
    <match>remote_code_execution|privilege_escalation|authentication_bypass|sql_injection</match>
    <description>PB-07 | High-impact vulnerability class detected</description>
    <group>vulnerability,high_impact,pb07,</group>
  </rule>
  <rule id="100065" level="11">
    <decoded_as>json</decoded_as>
    <match>missing_patch|patch_failed|critical_patch_missing|windows_update_failed</match>
    <description>PB-07 | Critical Windows patch missing or failed to apply</description>
    <group>vulnerability,windows_patch,pb07,</group>
  </rule>
</group>

<group name="cloud,misconfiguration,">
  <rule id="100090" level="14">
    <decoded_as>json</decoded_as>
    <match>s3_public_acl|bucket_made_public|PutBucketAcl.*AllUsers</match>
    <description>PB-10 | AWS S3 bucket ACL set to public — data exposure risk</description>
    <group>cloud,misconfiguration,aws,pb10,</group>
  </rule>
  <rule id="100091" level="13">
    <decoded_as>json</decoded_as>
    <match>security_group_open|sg_0000_ingress|AuthorizeSecurityGroupIngress</match>
    <description>PB-10 | AWS security group opened to internet on sensitive port</description>
    <group>cloud,misconfiguration,aws,pb10,</group>
  </rule>
  <rule id="100092" level="15">
    <decoded_as>json</decoded_as>
    <match>aws_root_login|root_account_used|root_api_call</match>
    <description>PB-10 | AWS root account used — critical security violation</description>
    <group>cloud,misconfiguration,aws,pb10,</group>
  </rule>
  <rule id="100093" level="13">
    <decoded_as>json</decoded_as>
    <match>azure_nsg_open|nsg_rdp_internet|nsg_ssh_internet</match>
    <description>PB-10 | Azure NSG rule allowing RDP or SSH from internet</description>
    <group>cloud,misconfiguration,azure,pb10,</group>
  </rule>
  <rule id="100094" level="14">
    <decoded_as>json</decoded_as>
    <match>guardduty_high|guardduty_finding|aws_threat_detected</match>
    <description>PB-10 | AWS GuardDuty high-severity finding detected</description>
    <group>cloud,misconfiguration,aws,pb10,</group>
  </rule>
  <rule id="100095" level="14">
    <decoded_as>json</decoded_as>
    <match>iam_admin_attached|AdministratorAccess_user|iam_privilege_escalation</match>
    <description>PB-10 | AWS IAM administrator policy attached directly to user</description>
    <group>cloud,misconfiguration,aws,pb10,</group>
  </rule>
</group>

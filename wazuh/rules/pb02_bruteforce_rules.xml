<group name="authentication,brute_force,">
  <rule id="100010" level="10">
    <decoded_as>json</decoded_as>
    <match>brute_force|failed_login|authentication_failure</match>
    <description>PB-02 | Brute force detected — multiple failed logins from single IP</description>
    <group>brute_force,authentication,pb02,</group>
  </rule>
  <rule id="100011" level="12">
    <decoded_as>json</decoded_as>
    <match>password_spray|spray_detected</match>
    <description>PB-02 | Password spray detected — multiple accounts targeted</description>
    <group>brute_force,password_spray,pb02,</group>
  </rule>
  <rule id="100012" level="14">
    <decoded_as>json</decoded_as>
    <match>credential_stuffing|success_after_fail</match>
    <description>PB-02 | Credential stuffing — brute force followed by successful login</description>
    <group>brute_force,credential_stuffing,pb02,</group>
  </rule>
  <rule id="100013" level="13">
    <decoded_as>json</decoded_as>
    <match>geo_anomaly|impossible_travel|country_mismatch</match>
    <description>PB-02 | Login from unexpected country — geo anomaly detected</description>
    <group>brute_force,geo_anomaly,pb02,</group>
  </rule>
  <rule id="100014" level="15">
    <decoded_as>json</decoded_as>
    <match>admin_brute_force|privileged_account_attack</match>
    <description>PB-02 | Privileged account brute force detected</description>
    <group>brute_force,privileged_account,pb02,</group>
  </rule>
  <rule id="100015" level="10">
    <decoded_as>json</decoded_as>
    <match>account_lockout|lockout_triggered</match>
    <description>PB-02 | Account lockout event triggered</description>
    <group>brute_force,account_lockout,pb02,</group>
  </rule>
</group>

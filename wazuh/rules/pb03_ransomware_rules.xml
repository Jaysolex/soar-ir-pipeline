<group name="ransomware,malware,endpoint,">
  <rule id="100020" level="15">
    <decoded_as>json</decoded_as>
    <match>\.locked|\.encrypted|\.enc|\.crypt|\.wncry|\.cerber|\.locky</match>
    <description>PB-03 | Ransomware — mass file extension rename detected</description>
    <group>ransomware,file_encryption,pb03,</group>
  </rule>
  <rule id="100021" level="14">
    <decoded_as>json</decoded_as>
    <match>README_FOR_DECRYPT|HOW_TO_DECRYPT|DECRYPT_INSTRUCTIONS|YOUR_FILES_ARE_ENCRYPTED</match>
    <description>PB-03 | Ransomware note file created on filesystem</description>
    <group>ransomware,ransom_note,pb03,</group>
  </rule>
  <rule id="100022" level="15">
    <decoded_as>json</decoded_as>
    <match>vssadmin.*delete|shadowcopy.*delete|bcdedit.*recoveryenabled.*no</match>
    <description>PB-03 | Volume shadow copy deletion — ransomware pre-encryption step</description>
    <group>ransomware,shadow_copy,pb03,</group>
  </rule>
  <rule id="100023" level="13">
    <decoded_as>json</decoded_as>
    <match>high_frequency_write|mass_file_write|encryption_in_progress</match>
    <description>PB-03 | High-frequency file write activity detected</description>
    <group>ransomware,file_activity,pb03,</group>
  </rule>
  <rule id="100024" level="15">
    <decoded_as>json</decoded_as>
    <match>wannacry|wcry|petya|notpetya|ryuk|conti|lockbit|blackcat|revil|sodinokibi</match>
    <description>PB-03 | Known ransomware binary name detected</description>
    <group>ransomware,known_malware,pb03,</group>
  </rule>
  <rule id="100025" level="12">
    <decoded_as>json</decoded_as>
    <match>network_share_access|smb_enumeration|lateral_spread</match>
    <description>PB-03 | Network share enumeration — potential ransomware lateral spread</description>
    <group>ransomware,lateral_movement,pb03,</group>
  </rule>
</group>

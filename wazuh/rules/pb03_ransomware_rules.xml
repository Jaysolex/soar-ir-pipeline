<group name="ransomware,malware,endpoint,pb03,">

  <rule id="100020" level="5">
    <if_sid>61603</if_sid>
    <description>PB-03 | Process creation event captured via Sysmon EventID 1</description>
    <group>ransomware,process_creation,pb03,</group>
  </rule>

  <rule id="100021" level="15">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.originalFileName">VSSADMIN.EXE</field>
    <field name="win.eventdata.commandLine">delete shadows</field>
    <description>PB-03 | Volume shadow copy deletion detected - vssadmin delete shadows</description>
    <group>ransomware,shadow_copy,pb03,</group>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>

  <rule id="100022" level="15">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.commandLine">bcdedit.*recoveryenabled.*no|bcdedit.*bootstatuspolicy</field>
    <description>PB-03 | Boot recovery disabled via bcdedit</description>
    <group>ransomware,boot_recovery,pb03,</group>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>

  <rule id="100023" level="15">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.originalFileName">wannacry|wcry|petya|notpetya|ryuk|conti|lockbit|blackcat|revil|sodinokibi</field>
    <description>PB-03 | Known ransomware binary name detected</description>
    <group>ransomware,known_malware,pb03,</group>
    <mitre>
      <id>T1486</id>
    </mitre>
  </rule>

  <rule id="100024" level="13">
    <if_sid>61600</if_sid>
    <field name="win.system.eventID">^11$</field>
    <field name="win.eventdata.targetFilename">\.locked$|\.encrypted$|\.enc$|\.crypt$|\.wncry$|\.cerber$</field>
    <description>PB-03 | Ransomware file extension detected</description>
    <group>ransomware,file_encryption,pb03,</group>
    <mitre>
      <id>T1486</id>
    </mitre>
  </rule>

  <rule id="100025" level="14">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.commandLine">wbadmin.*delete.*backup|wbadmin.*delete.*catalog</field>
    <description>PB-03 | Backup deletion via wbadmin detected</description>
    <group>ransomware,backup_deletion,pb03,</group>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>

</group>

<group name="phishing,email_security,">
  <rule id="100001" level="12">
    <decoded_as>json</decoded_as>
    <field name="rule_name">Suspicious External Phishing Email Reported</field>
    <description>PB-01 | Phishing email reported by user or blocked by gateway</description>
    <group>phishing,email,pb01,</group>
  </rule>
  <rule id="100002" level="14">
    <decoded_as>json</decoded_as>
    <match>\.exe|\.bat|\.ps1|\.vbs|\.hta|\.scr</match>
    <description>PB-01 | Executable attachment detected in inbound email</description>
    <group>phishing,email,malicious_attachment,pb01,</group>
  </rule>
  <rule id="100003" level="14">
    <decoded_as>json</decoded_as>
    <match>\.pdf\.exe|\.doc\.exe|\.xlsx\.exe|\.zip\.exe|\.pdf\.bat</match>
    <description>PB-01 | Double-extension attachment detected</description>
    <group>phishing,email,double_extension,pb01,</group>
  </rule>
  <rule id="100004" level="10">
    <decoded_as>json</decoded_as>
    <match>URGENT|IMMEDIATE|VERIFY NOW|Account Suspended|Banking Details|Password Expired</match>
    <description>PB-01 | High-urgency phishing subject line keyword detected</description>
    <group>phishing,email,social_engineering,pb01,</group>
  </rule>
  <rule id="100005" level="15">
    <decoded_as>json</decoded_as>
    <match>185\.220\.|45\.142\.|194\.165\.</match>
    <description>PB-01 | Inbound email from known Tor exit node or malicious IP range</description>
    <group>phishing,email,malicious_ip,pb01,</group>
  </rule>
</group>

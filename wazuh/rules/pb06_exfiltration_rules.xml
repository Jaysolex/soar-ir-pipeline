<group name="data_exfiltration,dlp,">
  <rule id="100050" level="13">
    <decoded_as>json</decoded_as>
    <match>large_outbound_transfer|bytes_sent_threshold|data_exfil_volume</match>
    <description>PB-06 | Large outbound transfer detected — 50MB or more sent to external destination</description>
    <group>data_exfiltration,large_transfer,pb06,</group>
  </rule>
  <rule id="100051" level="13">
    <decoded_as>json</decoded_as>
    <match>mega\.nz|wetransfer\.com|anonfiles\.com|gofile\.io|temp\.sh</match>
    <description>PB-06 | Bulk upload to unapproved file sharing service detected</description>
    <group>data_exfiltration,cloud_upload,pb06,</group>
  </rule>
  <rule id="100052" level="12">
    <decoded_as>json</decoded_as>
    <match>mass_document_access|bulk_file_read|sensitive_dir_access</match>
    <description>PB-06 | Mass document access — bulk sensitive file reads detected</description>
    <group>data_exfiltration,file_access,pb06,</group>
  </rule>
  <rule id="100053" level="13">
    <decoded_as>json</decoded_as>
    <match>gmail\.com|yahoo\.com|protonmail\.com|personal_email_attachment</match>
    <description>PB-06 | Large attachment sent to personal email address</description>
    <group>data_exfiltration,email,pb06,</group>
  </rule>
  <rule id="100054" level="12">
    <decoded_as>json</decoded_as>
    <match>usb_copy|removable_storage|dlp_usb_alert|classified_to_usb</match>
    <description>PB-06 | Classified data copied to USB removable storage</description>
    <group>data_exfiltration,usb,pb06,</group>
  </rule>
  <rule id="100055" level="14">
    <decoded_as>json</decoded_as>
    <match>dns_tunnel|dns_exfil|long_dns_query|dns_txt_anomaly</match>
    <description>PB-06 | Anomalous DNS query — potential DNS tunneling exfiltration</description>
    <group>data_exfiltration,dns_tunnel,pb06,</group>
  </rule>
</group>
